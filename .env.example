# Supabase proje bilgilerinizi buraya girin.
# Supabase Dashboard > Project Settings > API üzerinden bulabilirsiniz.
# Bu değerler EXPO_PUBLIC_ önekiyle başladığı için istemci (mobil) tarafına gömülür;
# yalnızca "anon" (publishable) anahtarı kullanın, service_role anahtarını ASLA buraya koymayın.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Web Push (ekran kilitliyken/PWA arka plandayken bildirim) için VAPID public key.
# `npx web-push generate-vapid-keys` ile üretilir; private key BURAYA DEĞİL,
# Supabase Edge Function secret'ı olarak saklanır (bkz. SETUP.md).
EXPO_PUBLIC_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
