# Supabase proje bilgilerinizi buraya girin.
# Supabase Dashboard > Project Settings > API üzerinden bulabilirsiniz.
# Bu değerler EXPO_PUBLIC_ önekiyle başladığı için istemci (mobil) tarafına gömülür;
# yalnızca "anon" (publishable) anahtarı kullanın, service_role anahtarını ASLA buraya koymayın.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
