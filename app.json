{
  "expo": {
    "name": "OfisNow",
    "slug": "ofisnow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ofisnow",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ofisnow.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ofisnow.app",
      "adaptiveIcon": {
        "backgroundColor": "#00236f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#00236f",
          "sounds": [
            "./assets/sounds/new_order.wav"
          ],
          "mode": "production"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçebilmek için fotoğraflarınıza erişim izni gerekiyor."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "258bffdd-bf51-4bfa-b722-bcd193142ae3"
      }
    },
    "owner": "mehmetdemirkok"
  }
}
